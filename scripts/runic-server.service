[Unit]
Description=Runic Firewall Control Plane
Documentation=https://github.com/ubenmackin/runic
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=runic
Group=runic
WorkingDirectory=/opt/runic
ExecStart=/opt/runic/dist/runic-server
Restart=on-failure
RestartSec=10s

# Load secrets from environment file
EnvironmentFile=/opt/runic/.env

# Environment variables for non-secret configuration
Environment=RUNIC_DB_PATH=%DATA_DIR%/runic.db

# Security hardening
NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=yes
ProtectSystem=strict
ReadWritePaths=/opt/runic/data
ReadOnlyPaths=/etc/ssl/certs

# Resource limits
LimitNOFILE=65536
MemoryMax=512M

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=runic-server

[Install]
WantedBy=multi-user.target
